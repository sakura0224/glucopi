<wxs src="./index.wxs" module="utils" />

<t-navbar t-class-placeholder="t-navbar-placeholder" t-class-content="t-navbar-content" title="全部消息" t-class-title="nav-title" />
<scroll-view class="message-list" scroll-y refresher-enabled refresher-triggered="{{ loading }}" bindrefresherrefresh="getMessageList">
  <t-cell wx:for="{{ messageList }}" wx:key="index" t-class-image="avatar" t-class-description="content {{ item.unread === 0 ? '' : 'unread' }}" image="{{ item.avatar || 'https://cdn.ayane.top/avatar/default.png' }}" title="{{ item.name || '微信用户' }}" description="{{ item.lastMessage }}" hover bind:tap="toChat" data-user-id="{{ item.userId }}">
    <t-badge slot="right-icon" count="{{ item.unread }}" class="wrapper" />
  </t-cell>

  <t-fab icon="chat-bubble" bind:click="handleClick" text="智能助手" />
</scroll-view>